generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model UserPurchase {
  id              String   @id @default(cuid())
  name            String   
  email           String   @unique
  stripeSessionId String   @unique
  paymentStatus   String   @default("pending")
  downloadCount   Int      @default(0)
  createdAt       DateTime @default(now())
}